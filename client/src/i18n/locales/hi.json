  "manual": {
    "title": "उपयोगकर्ता मार्गदर्शिका",
    "toc": "विषय सूची",
    "companies": {
      "title": "कंपनियों का प्रबंधन",
      "content": "नई कंपनी जोड़ने के लिए, नेविगेशन बार में 'कंपनियाँ' लिंक पर क्लिक करें, फिर 'कंपनी जोड़ें' पर क्लिक करें। कंपनी का नाम, टैक्स आईडी, पंजीकरण संख्या, पता, शहर और पिन कोड भरें। कंपनी का विवरण आपके द्वारा बनाए गए सभी पे स्लिप में स्वचालित रूप से भर जाएगा। आप कंपनियों की सूची में क्लिक करके किसी भी समय कंपनी के विवरण को संपादित कर सकते हैं।"
    },
    "employees": {
      "title": "कर्मचारियों का प्रबंधन",
      "content": "नया कर्मचारी जोड़ने के लिए, नेविगेशन बार में 'कर्मचारी' लिंक पर क्लिक करें, फिर 'कर्मचारी जोड़ें' पर क्लिक करें। कर्मचारी का पूरा नाम, पासपोर्ट या आईडी नंबर, राष्ट्रीयता, नौकरी का शीर्षक, विभाग, रोजगार प्रारंभ तिथि, वेतन आधार और दस्तावेज़ निर्माण के लिए पसंदीदा भाषा सहित व्यक्तिगत विवरण भरें। कर्मचारी की पसंदीदा भाषा का उपयोग ईमेल द्वारा दस्तावेज़ भेजते समय डिफ़ॉल्ट के रूप में किया जाएगा।"
    },
    "payslip": {
      "title": "पे स्लिप बनाना",
      "content": "नया पे स्लिप बनाने के लिए, नेविगेशन बार या डैशबोर्ड से 'नया पे स्लिप' पर क्लिक करें। वेतन अवधि (महीना और वर्ष) चुनें, फिर कर्मचारी विवरण, कार्य दिवसों का विवरण, वेतन, कटौतियाँ और नियोक्ता का योगदान भरें। सिस्टम इज़राइली कानून के अनुसार आयकर, राष्ट्रीय बीमा और स्वास्थ्य बीमा की गणना स्वचालित रूप से करता है। 'मैन्युअल मूल्य' पर स्विच करके किसी भी गणना की गई मान को ओवरराइड किया जा सकता है।"
    },
