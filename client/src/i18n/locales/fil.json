  "manual": {
    "title": "Gabay ng Gumagamit",
    "toc": "Talaan ng Nilalaman",
    "companies": {
      "title": "Pamamahala ng mga Kumpanya",
      "content": "Upang magdagdag ng bagong kumpanya, i-click ang link na 'Mga Kumpanya' sa navigation bar, pagkatapos ay i-click ang 'Magdagdag ng Kumpanya'. Punan ang pangalan ng kumpanya, tax ID, numero ng pagpaparehistro, address, lungsod, at zip code. Ang mga detalye ng kumpanya ay awtomatikong mapupuno sa lahat ng payslip na iyong lilikhain. Maaari mong i-edit ang mga detalye ng kumpanya anumang oras sa pamamagitan ng pag-click dito sa listahan ng mga kumpanya."
    },
    "employees": {
      "title": "Pamamahala ng mga Empleyado",
      "content": "Upang magdagdag ng bagong empleyado, i-click ang link na 'Mga Empleyado' sa navigation bar, pagkatapos ay i-click ang 'Magdagdag ng Empleyado'. Punan ang personal na impormasyon ng empleyado kabilang ang buong pangalan, numero ng pasaporte o ID, nasyonalidad, titulo ng trabaho, departamento, petsa ng simula ng trabaho, batayan ng sahod, at gustong wika para sa paglikha ng dokumento. Ang gustong wika ng empleyado ay gagamitin bilang default kapag nagpapadala ng mga dokumento sa kanya sa pamamagitan ng email."
    },
    "payslip": {
      "title": "Paglikha ng Payslip",
      "content": "Upang lumikha ng bagong payslip, i-click ang 'Bagong Payslip' sa navigation bar o mula sa dashboard. Piliin ang panahon ng sahod (buwan at taon), pagkatapos punan ang mga detalye ng empleyado, breakdown ng araw ng trabaho, sahod, mga bawas, at mga kontribusyon ng employer. Awtomatikong kinakalkula ng sistema ang income tax, national insurance, at health insurance batay sa batas ng Israel. Maaari mong i-override ang anumang kinalkulang halaga sa pamamagitan ng pagpapalit sa 'Manu-manong halaga'. I-click ang 'I-save' anumang oras upang i-save ang iyong progreso."
    },
    "fields": {
      "title": "Sanggunian ng Field (Legal na Kahulugan)",
      "content": "Income Tax: Binabawas batay sa progressive tax brackets ayon sa Income Tax Ordinance. National Insurance (Empleyado): Binabawas mula sa sahod ng empleyado ayon sa National Insurance Law. Health Insurance: Kontribusyon ng empleyado sa national health insurance fund. Pension: Parehong employer at empleyado ay kailangang mag-ambag sa pension fund ayon sa Mandatory Pension Law. Severance Fund: Mga kontribusyon ng employer para sa severance pay entitlement. Education Fund: Boluntaryong savings scheme kung saan nag-aambag parehong employer at empleyado bawat buwan. Recuperation Pay: Taunang bayad sa mga empleyado para sa mga araw ng pagpapagaling."
    },
    "export": {
      "title": "Pag-export sa PDF",
      "content": "Kapag na-save na ang iyong payslip, i-click ang pindutang 'Gumawa ng PDF'. Lilitaw ang isang dialog kung saan maaari kang pumili ng output language para sa PDF. Ang PDF ay nilikha nang buo sa iyong browser at naka-format ayon sa mga kinakailangan ng batas sa paggawa ng Israel. Upang direktang ipadala ang dokumento sa empleyado sa pamamagitan ng email, i-click ang pindutang 'Ipadala sa Empleyado' (nangangailangan ng aktibong subscription)."
    },
    "subscription": {
      "title": "Mga Benepisyo ng Subscription",
      "content": "Ang subscription ay nagbubukas ng kakayahang magpadala ng mga payslip at final settlement document nang direkta sa mga empleyado sa pamamagitan ng email. Ang mga libreng account ay limitado sa 3 pagpapadala bawat araw. Sa isang subscription, makakakuha ka ng walang limitasyong araw-araw na pagpapadala at access sa lahat ng advanced na feature ng sistema."
    }
  },
