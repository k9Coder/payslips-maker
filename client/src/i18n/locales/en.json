  "manual": {
    "title": "User Guide",
    "toc": "Table of Contents",
    "companies": {
      "title": "Managing Companies",
      "content": "To add a new company, click the 'Companies' link in the navigation bar, then click 'Add Company'. Fill in the company name, tax ID (Employer Tax ID / Company No.), registration number, address, city, and zip code. Company details are automatically populated in all payslips you create under that company. You can edit a company's details at any time by clicking on it in the companies list."
    },
    "employees": {
      "title": "Managing Employees",
      "content": "To add a new employee, click the 'Employees' link in the navigation bar, then click 'Add Employee'. Fill in the employee's personal details including full name, passport or ID number, nationality, job title, department, employment start date, salary basis (monthly, daily, or hourly), and preferred language for document generation. The employee's preferred language will be used as the default when sending email documents to them."
    },
    "payslip": {
      "title": "Creating a Payslip",
      "content": "To create a new payslip, click 'New Payslip' in the navigation bar or from the dashboard. Select the pay period (month and year), then fill in the employee details, work days breakdown, salary, deductions, and employer contributions. The system automatically calculates income tax, national insurance, and health insurance based on Israeli law. You can override any calculated value by toggling to 'Manual value'. Click 'Save' at any time to save your progress."
    },
    "fields": {
      "title": "Field Reference (Legal Meaning)",
      "content": "Income Tax: Deducted based on progressive tax brackets under the Income Tax Ordinance. National Insurance (Employee): Deducted from the employee's salary under the National Insurance Law. Health Insurance: The employee's contribution to the national health insurance fund. Pension: Both employer and employee are required to contribute to a pension fund per the Mandatory Pension Law (2008). Severance Fund: Employer contributions toward severance pay entitlement. Education Fund: A voluntary savings scheme where both employer and employee contribute monthly. Recuperation Pay: Annual entitlement paid to employees for recuperation days."
    },
    "export": {
      "title": "Exporting to PDF",
      "content": "Once your payslip is saved, click the 'Generate PDF' button. A dialog will appear where you can select the output language for the PDF. The PDF is generated entirely in your browser and formatted according to Israeli labor law requirements. To send the document directly to the employee by email, click the 'Send to Employee' button (requires an active subscription)."
    },
    "subscription": {
      "title": "Subscription Benefits",
      "content": "A subscription unlocks the ability to send payslips and final settlement documents directly to employees by email. Free accounts are limited to 3 email sends per day. With a subscription, you get unlimited daily sends. Subscriptions also unlock access to the archive for viewing older documents and any future premium features added to the platform."
    }
  },
